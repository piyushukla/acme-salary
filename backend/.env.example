# Local dev: a plain SQLite file. Prisma creates it on `db:push`.
DATABASE_URL="file:./dev.db"

# Single auth gate for the HR Manager (see requirements: RBAC is deliberately out of scope).
API_TOKEN="dev-hr-token-change-me"

# Frontend origin allowed by CORS.
CORS_ORIGIN="http://localhost:5173"

PORT=4000

# --- For deploy on Turso (serverless-safe SQLite) ---
# DATABASE_URL="libsql://<your-db>.turso.io"
# DATABASE_AUTH_TOKEN="<turso-token>"
